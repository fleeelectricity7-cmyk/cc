        LoadingTitle = "Đang kiểm tra Sub4Unlock...",
        KeySystem = true,
        KeySettings = { Title = "Nhập Key Ngày", Key = {DynamicKey}, Info = "Lấy Key tại: " .. MySubLink }
    })
    repeat task.wait() until _G.KeyInputted == true
end

