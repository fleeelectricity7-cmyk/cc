-- [[ 5. HỆ THỐNG VẬN HÀNH NGẦM (LOGIC V36) ]]
local VirtualUser = game:GetService("VirtualUser")
local LP = game.Players.LocalPlayer

spawn(function()
    while task.wait() do
        -- 5.1 Xử lý No Animation & Fast Attack (Leaf Hub)
        if _G.LeafFastAttack then
            pcall(function()
                local Framework = require(LP.PlayerScripts.CombatFramework)
                local Rig = Framework.activeController
                if Rig and Rig.equipped then
                    Rig.timeToNextAttack = 0
                    Rig.hitboxMagnitude = 60
                    if _G.LeafAutoClick then VirtualUser:ClickButton1(Vector2.new(0,0)) end
                    if _G.NoAnimation then
                        for _,v in pairs(LP.Character.Humanoid:GetPlayingAnimationTracks()) do
                            if v.Name:find("Attack") or v.Name:find("Slash") then v:Stop() end
                        end
                    end
                end
            end)
        end

        -- 5.2 Logic Auto Farm Boss
        if _G.AutoFarmBoss then
            pcall(function()
                local Bosses = game:GetService("Workspace").Enemies:GetChildren()
                local FoundBoss = false
                for _, boss in pairs(Bosses) do
                    if boss:FindFirstChild("Humanoid") and boss.Humanoid.Health > 0 then
                        if _G.SelectedBoss == "All Boss" or boss.Name == _G.SelectedBoss then
                            FoundBoss = true
                            -- Bay đến Boss và chém
                            LP.Character.HumanoidRootPart.CFrame = boss.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)
                            VirtualUser:ClickButton1(Vector2.new(0,0))
                        end
                    end
                end
                
                -- Nếu bật Auto Hop và không tìm thấy Boss
                if not FoundBoss and _G.AutoHopBoss then
                    print("Không thấy Boss, chuẩn bị đổi server...")
                    task.wait(3)
                    -- Thực hiện Hop Server
                end
            end)
        end
    end
end)

-- 5.3 Nhắc nợ Duy (Duy dùng là bị đòi nợ)
